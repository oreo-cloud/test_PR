        string std_num_string;
        string gra_num_string;
        int std_num = 0;
        int gra_num = 0;
        while (1) {
          cout << "Input a lower bound on the number of students: ";
          cin >> std_num_string;
          cout << "\n";
          if (list.IsNumber(std_num_string)) {  //確認字串為數字後，即轉為整數型態
            std_num = stoi(std_num_string);
            if (std_num >= 0 && std_num <= 9999) {
              break;
            } else {
              cout << "### It is NOT in [0,9999] ###\n\n";
            }
          }
        }
        while (1) {
          cout << "Input a lower bound on the number of graduates: ";
          cin >> gra_num_string;
          cout << "\n";
          if (list.IsNumber(gra_num_string)) {  //確認字串為數字後，即轉為整數型態
            gra_num = stoi(gra_num_string);
            if (gra_num >= 0 && gra_num <= 9999) {
              break;
            } else {
              cout << "### It is NOT in [0,9999] ###\n\n";
            }
          }
        }
        list.SelectFile(copy_file, std_num, gra_num, input);  //篩選資料並覆蓋
        cout << "\n";
        return;
      }
    }
  }
  
  void M3() {
    bool exist_file1 = false;
    string file1_string;
    string file2_string;
    while(1) {
      cout << "Input 201, 202, ...[0]Quit): ";
      string input;
      cin >> input;
      cout << "\n";
      ifstream check_file;
      string copy_file_name = "copy" + input + ".txt";
      check_file.open(copy_file_name);
      if (input == "0") {
        return;
      } else if (!check_file.is_open()) {  //用check_file確認copy檔是否存在
        cout << "### copy" << input << ".txt does not exist! ###\n\n";
        continue;
      } else if (check_file.peek() == EOF) {  //如果檔案存在，但資料為空，則直接結束
        return;
      } else {
        if (!exist_file1) {  //如果第一個檔還沒有存在
          exist_file1 = true;
          file1_string = input;  //將input存入file1_string
        } else {  //第一個檔已存在
          file2_string = input;  //將input存入file2_string
          ifstream file1;
          ifstream file2;
          string copy_file1_name = "copy" + file1_string + ".txt";
          string copy_file2_name = "copy" + file2_string + ".txt";
          file1.open(copy_file1_name);
          file2.open(copy_file2_name);
          list.MergeFile(file1, file2, file1_string, file2_string, false);  //合併兩個檔案，false為任務四判斷時使用
          vector<string> file_name_array = list.FileNameArray();  //取得檔名vector
          list.OutputMergeFile(file_name_array);  //輸出合併檔
          int sum = list.GetSum();  //取得合併後總筆數
          cout << "Number of records = " << sum << "\n";  //輸出總筆數
          cout << "\n";
          return;
        }
      }
    }
  }

  void M4() {
    bool exist_file1 = false;
    bool file1_is_saved = false;
    string file1_string;
    int merged_num = 0;
    int merged_num_check = 0;
    while(1) {
      string file2_string;
      cout << "Input 201, 202, ...[0]Quit): ";
      string input;
      cin >> input;
      cout << "\n";
      ifstream check_file;
      string copy_file_name = "copy" + input + ".txt";
      check_file.open(copy_file_name);
      if (input == "0") {
        return;
      } else if (!check_file.is_open()) {  //用check_file確認copy檔是否存在
        cout << "### copy" << input << ".txt does not exist! ###\n\n";
        continue;
      } else if (check_file.peek() == EOF) {  //如果檔案存在，但資料為空，則直接結束
        return;
      } else {
        if (!exist_file1) {  //如果第一個檔還沒有存在
          exist_file1 = true;
          file1_string = input;  //將input存入file1_string
          ifstream file1;
          string copy_file1_name = "copy" + file1_string + ".txt";
          file1.open(copy_file1_name);  //開啟基準檔
          while (1) {
            string merged_num_string;
            cout << "Input the number of files to be merged: ";
            cin >> merged_num_string;
            cout << "\n";
            if (list.IsNumber(merged_num_string)) {
              merged_num = stoi(merged_num_string);
              if (merged_num >= 1 && merged_num <= 4) {
                break;
              } else {
                cout << "### It is NOT in [1,4] ###\n\n";
              }
            } 
          }
        } else {  //第一個檔已存在
